    "moment": "^2.30.1",
    "nanoid": "^5.1.11",
    "nodemailer": "^8.0.1",
    "pino": "^10.2.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "puppeteer": "^24.36.1",
