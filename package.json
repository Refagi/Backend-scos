    "@types/passport": "^1.0.17",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.0.0",
    "prettier": "3.7.4",
    "tsc-alias": "^1.8.17",
    "typescript-eslint": "^8.53.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@faker-js/faker": "^10.3.0",
